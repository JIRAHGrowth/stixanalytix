# dependencies
node_modules/

# environment files
.env
.env.local
.env*.local

# next.js
.next/
out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
dev.log

# vercel
.vercel

# claude code local settings
.claude/

# python (video worker)
__pycache__/
*.py[cod]
.venv/
worker/.venv/

# gemini test outputs (ephemeral)
scripts/results/

# ground-truth: commit the .xlsx templates and any per-match .xlsx, but the
# .json files are generated by scripts/excel-to-ground-truth.js — derived,
# not source.
scripts/ground-truth/*.json

# eval reports — produced by scripts/eval-match.js with --save-report
scripts/eval-reports/

# bench harness — model-comparison outputs and downloaded source videos
scripts/.bench-videos/
# Per-run bench job outputs are large; commit only the scorecard summaries.
scripts/bench-results/*
!scripts/bench-results/scorecards/
!scripts/bench-results/scorecards/.gitkeep

# GCP service account credentials — NEVER commit.
.gcp-key.json
*.gcp-key.json
*-credentials.json

# SFT training corpus — regenerable via scripts/build-sft-training-data.py.
# Keep .stats.json (audit trail of what was built) but not the JSONL itself.
training/*.jsonl

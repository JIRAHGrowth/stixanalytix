{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(grep -n \"^//\" \"C:\\\\Users\\\\joshu\\\\Desktop\\\\stixanalytix\\\\app\\\\dashboard\\\\page.jsx\")"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "out=$(git pull --ff-only 2>&1); code=$?; if [ $code -ne 0 ]; then msg=$(echo \"$out\" | tr '\\n' ' ' | sed 's/\"/\\\\\"/g'); printf '{\"systemMessage\":\"git pull failed: %s\"}\\n' \"$msg\"; fi",
            "timeout": 30,
            "statusMessage": "Pulling latest from origin/main..."
          }
        ]
      }
    ]
  }
}

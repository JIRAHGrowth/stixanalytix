# Copy to .env.local and fill in. Never commit .env.local.

# ============================================================================
# Supabase (Next.js app + video worker both use these)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://lmwbvkyqyhagqegewnyd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================================
# Gemini (video worker)
# ============================================================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ============================================================================
# Error tracking — D3 pending, placeholder
# ============================================================================
# SENTRY_DSN=

# ============================================================================
# Modal credentials live in ~/.modal.toml after `python -m modal setup`.
